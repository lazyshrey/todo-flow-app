# ==============================================================================
# Global Monorepo Environment Variables
# Copy this file to '.env' and fill in your credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Clerk Authentication (Used by apps/web)
# Sign up at https://clerk.com to get these keys for your local Next.js project.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ------------------------------------------------------------------------------
# 2. Discord Bot Settings (Used by apps/discord-bot)
# Obtain these from the Discord Developer Portal (https://discord.com/developers/applications)
# ------------------------------------------------------------------------------
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# ------------------------------------------------------------------------------
# 3. Secure Shared Secrets (Used by apps/web & apps/discord-bot)
# Create a secure random string (e.g. generate a long random password).
# ------------------------------------------------------------------------------
DISCORD_BOT_SECRET=change_me_to_a_secure_random_string_123!

# ------------------------------------------------------------------------------
# 4. Service Connection URLs
# ------------------------------------------------------------------------------
# Next.js API endpoints connection configuration
API_URL=http://localhost:3000/api
